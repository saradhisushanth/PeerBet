# Session pooler (runtime) — used by the app at runtime
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require"

# Direct connection — used by Prisma CLI for migrations only
# Format: postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres
DIRECT_URL="postgresql://postgres.xxxxxxxxxxxx:PASSWORD@db.xxxxxxxxxxxx.supabase.co:5432/postgres?sslmode=require"

PORT=3001
CLIENT_URL="http://localhost:5173"
JWT_SECRET="your-secret-key-here"
