# PostgreSQL connection (local or hosted). Used by Prisma CLI (prisma.config.ts) and the API.
# Supabase: use the pooler URI from Dashboard → Settings → Database → Connection string
# (often user postgres.PROJECT_REF, host aws-*-REGION.pooler.supabase.com, port 5432 or 6543).
DATABASE_URL="postgresql://user:password@localhost:5432/postgres"

# API port. Must match what Vite proxies to (client reads this from the same file).
PORT=3001

# Allowed browser origin for CORS + Socket.io (Vite dev server URL).
CLIENT_URL="http://localhost:5173"

# Secret for JWT signing — use a long random string in production.
JWT_SECRET="change-me-in-development"
